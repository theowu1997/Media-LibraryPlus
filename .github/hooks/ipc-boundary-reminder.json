{
    "hooks": {
        "PreToolUse": [
            {
                "type": "command",
                "windows": {
                    "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/hooks/ipc-boundary-guard.ps1"
                },
                "linux": {
                    "command": "pwsh -NoProfile -File scripts/hooks/ipc-boundary-guard.ps1"
                },
                "osx": {
                    "command": "pwsh -NoProfile -File scripts/hooks/ipc-boundary-guard.ps1"
                },
                "timeout": 8
            }
        ],
        "UserPromptSubmit": [
            {
                "type": "command",
                "windows": {
                    "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/hooks/ipc-boundary-reminder.ps1"
                },
                "linux": {
                    "command": "pwsh -NoProfile -File scripts/hooks/ipc-boundary-reminder.ps1"
                },
                "osx": {
                    "command": "pwsh -NoProfile -File scripts/hooks/ipc-boundary-reminder.ps1"
                },
                "timeout": 8
            }
        ]
    }
}