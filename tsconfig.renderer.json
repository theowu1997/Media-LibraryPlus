{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "app/renderer/src/**/*.ts",
    "app/renderer/src/**/*.tsx",
    "app/shared/**/*.ts"
  ],
  "exclude": [
    "app/renderer/src/__tests__"
  ]
}
